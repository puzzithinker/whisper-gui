{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "store:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "whisperx", "cmd": "whisperx", "args": true },
        { "name": "python", "cmd": "python", "args": true },
        { "name": "python3", "cmd": "python3", "args": true },
        { "name": "nvidia-smi", "cmd": "nvidia-smi", "args": true },
        { "name": "ffmpeg", "cmd": "ffmpeg", "args": true }
      ]
    },
    "shell:allow-execute",
    "shell:allow-kill",
    "shell:allow-stdin-write"
  ]
}